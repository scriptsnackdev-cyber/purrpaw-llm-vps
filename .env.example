# Server Configuration
PORT=8080

# Supabase Credentials (Direct Backend Access)
# Ensure the service role key is used to bypass RLS for fetching user metadata and saving logs securely
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Google Cloud Vertex AI Configuration
# The server will automatically search for the Service Account JSON credentials
# using the GOOGLE_APPLICATION_CREDENTIALS environment variable.
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
